{
  "name": "weather",
  "description": "Weather information via wttr.in",
  "prompt": "You can check the weather using the get_weather tool. It returns a concise weather summary for any city.",
  "tools": [
    {
      "name": "get_weather",
      "description": "Get current weather for a location",
      "type": "http",
      "method": "GET",
      "url": "https://wttr.in/{{location}}?format=j1",
      "headers": {
        "Accept": "application/json"
      },
      "timeout": 15,
      "parameters": {
        "type": "object",
        "properties": {
          "location": {
            "type": "string",
            "description": "City name or location (e.g. 'London', 'New+York', 'Tokyo')"
          }
        },
        "required": ["location"]
      }
    }
  ]
}
