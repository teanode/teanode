{
  "name": "echo",
  "description": "Simple echo tool for testing the skill system",
  "tools": [
    {
      "name": "echo_test",
      "description": "Echo back the input message (useful for testing)",
      "type": "shell",
      "command": ["echo", "{{message}}"],
      "timeout": 5,
      "parameters": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "The message to echo back"
          }
        },
        "required": ["message"]
      }
    }
  ]
}
