{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Name",
      "titleKey": "schema.agent.fields.name.title",
      "description": "Friendly display name for this agent.",
      "descriptionKey": "schema.agent.fields.name.description"
    },
    "model": {
      "type": "string",
      "title": "Model",
      "titleKey": "schema.agent.fields.model.title",
      "description": "Qualified model override (e.g. openai:gpt-5.2). Defaults to global model.",
      "descriptionKey": "schema.agent.fields.model.description",
      "x-placeholder": "Default",
      "x-suggest": "model"
    },
    "tools": {
      "type": "array",
      "title": "Tools",
      "titleKey": "schema.agent.fields.tools.title",
      "description": "Tool names to allow. Leave empty to allow all tools.",
      "descriptionKey": "schema.agent.fields.tools.description",
      "items": { "type": "string" },
      "x-suggest": "tool"
    },
    "skills": {
      "type": "array",
      "title": "Skills",
      "titleKey": "schema.agent.fields.skills.title",
      "description": "Skill names to allow. Leave empty to allow all skills.",
      "descriptionKey": "schema.agent.fields.skills.description",
      "items": { "type": "string" },
      "x-suggest": "skill"
    }
  },
  "x-sections": [
    {
      "id": "general",
      "title": "General",
      "titleKey": "schema.agent.sections.general.title",
      "description": "Core agent settings. Model-level limits are configured under global models.",
      "descriptionKey": "schema.agent.sections.general.description",
      "properties": ["name", "model", "tools", "skills"]
    }
  ]
}
