{
  "manifest_version": 3,
  "name": "TeaNode",
  "version": "0.2.0",
  "description": "Attach TeaNode to your browser — CDP relay + credentialed tab tools.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "storage",
    "cookies",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "dist/background.js", "type": "module" },
  "side_panel": {
    "default_path": "dist/sidepanel.html"
  },
  "action": {
    "default_title": "TeaNode",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/overlay.html", "dist/overlay.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "options.html"
}
